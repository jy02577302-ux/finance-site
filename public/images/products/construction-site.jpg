  <rect x="90" y="170" width="20" height="80" fill="#4b5563"/>
  <rect x="130" y="170" width="20" height="80" fill="#4b5563"/>
  <rect x="170" y="170" width="20" height="80" fill="#4b5563"/>
  <rect x="210" y="170" width="20" height="80" fill="#4b5563"/>
