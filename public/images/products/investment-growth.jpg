<svg width="1200" height="500" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="invGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#064e3b"/>
      <stop offset="100%" style="stop-color:#111827"/>
    </linearGradient>
    <linearGradient id="chartLine" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#10b981"/>
      <stop offset="100%" style="stop-color:#d4a855"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="500" fill="url(#invGrad)"/>
  <text x="600" y="80" font-family="Inter,Arial" font-size="32" fill="#d4a855" text-anchor="middle" font-weight="bold">投资贷款 · 财富增长</text>
  <g stroke="#374151" stroke-width="1">
    <line x1="100" y1="450" x2="1100" y2="450"/>
    <line x1="100" y1="100" x2="100" y2="450"/>
  </g>
  <g fill="#6b7280" font-size="12" text-anchor="middle">
    <text x="100" y="470">0</text>
    <text x="300" y="470">1 年</text>
    <text x="600" y="470">3 年</text>
    <text x="900" y="470">5 年</text>
    <text x="1100" y="470">10 年</text>
  </g>
  <path d="M100,400 L200,340 L300,300 L400,260 L500,220 L600,180 L700,150 L800,120 L900,100 L1000,80 L1100,60" stroke="url(#chartLine)" stroke-width="4" fill="none"/>
  <circle cx="100" cy="400" r="6" fill="#10b981"/>
  <circle cx="200" cy="340" r="6" fill="#10b981"/>
  <circle cx="300" cy="300" r="6" fill="#10b981"/>
  <circle cx="400" cy="260" r="6" fill="#10b981"/>
  <circle cx="500" cy="220" r="6" fill="#10b981"/>
  <circle cx="600" cy="180" r="6" fill="#d4a855"/>
  <circle cx="700" cy="150" r="6" fill="#d4a855"/>
  <circle cx="800" cy="120" r="6" fill="#d4a855"/>
  <circle cx="900" cy="100" r="6" fill="#d4a855"/>
  <circle cx="1000" cy="80" r="6" fill="#d4a855"/>
  <circle cx="1100" cy="60" r="6" fill="#d4a855"/>
  <text x="600" y="30" font-family="Inter,Arial" font-size="16" fill="#9ca3af" text-anchor="middle">负扣税 + 资本增长 = 最大化回报</text>
</svg>